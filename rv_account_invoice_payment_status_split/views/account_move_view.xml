<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override Customer Invoice action (Odoo 18 way) -->
    <record id="account.action_move_out_invoice_type" model="ir.actions.act_window">
        <field name="context">{'default_move_type': 'out_invoice', 'move_type': 'out_invoice', 'journal_type': 'sale', 'group_by': [], 'search_default_group_by_payment_status_group': 0}</field>
    </record>

    <!-- Inherit Customer Invoice Form View - Restrict address fields -->
    <record id="view_move_form_inherit_rv_address_restrict" model="ir.ui.view">
        <field name="name">account.move.form.inherit.rv_address_restrict</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Restrict Delivery Address to only the selected customer's addresses -->
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="domain">['|', ('id', '=', partner_id), ('parent_id', '=', partner_id)]</attribute>
                <attribute name="no_create">1</attribute>
                <attribute name="no_create_edit">1</attribute>
                <attribute name="no_quick_create">1</attribute>
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Accounting Dashboard Kanban - Add Upload button to Customer Invoices -->
    <record id="account_journal_dashboard_kanban_inherit_rv_upload" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.inherit.rv_upload</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">
            <!-- Replace sale journal buttons: Add Upload + New (same layout as purchase) -->
            <xpath expr="//t[@t-name='JournalBodySalePurchase']//t[@t-if=&quot;journal_type == 'sale'&quot;]" position="replace">
                <t t-if="journal_type == 'sale'">
                    <div t-if="!journal_is_empty" class="d-flex">
                        <widget name="account_file_uploader" btnClass="btn btn-primary oe_kanban_action"/>
                        <div class="ms-1">
                            <button type="object" name="action_create_new" class="btn-secondary" groups="account.group_account_invoice">New</button>
                        </div>
                    </div>
                    <div t-else="">
                        <widget name="account_file_uploader" btnClass="btn btn-primary oe_kanban_action"/>
                        <widget name="account_onboarding" t-if="dashboard['onboarding']"/>
                    </div>
                </t>
            </xpath>
        </field>
    </record>

</odoo>
