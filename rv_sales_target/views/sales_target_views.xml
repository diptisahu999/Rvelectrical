<odoo>

    <!-- FORM VIEW -->
    <record id="view_sales_target_form" model="ir.ui.view">
        <field name="name">sales.target.form</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <form string="Sales Target">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                        </group>
                        <group>  
                            <field name="date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Targets">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="month" width="25%"/>
                                    <field name="year" width="15%"/>
                                    <field name="assigned_date" invisible="0" readonly="1"/>
                                    <field name="target_amount" width="25%"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_sales_target_tree" model="ir.ui.view">
        <field name="name">sales.target.tree</field>
        <field name="model">sales.target</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sales_target" model="ir.actions.act_window">
        <field name="name">Sales Target</field>
        <field name="res_model">sales.target</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- SALES TOP BAR MENU -->
    <menuitem
        id="menu_sales_target"
        name="Sales Target"
        parent="sale.sale_menu_root"
        action="action_sales_target"
        sequence="15"/>


</odoo>
