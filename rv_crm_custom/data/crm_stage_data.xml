<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- New: Blue (Color 4) -->
        <function model="crm.stage" name="write">
            <value model="crm.stage" eval="obj().search([('name', '=', 'New')]).ids"/>
            <value eval="{'color': 4}"/>
        </function>
        <!-- Quotation: Orange (Color 3) -->
        <function model="crm.stage" name="write">
            <value model="crm.stage" eval="obj().search([('name', '=', 'Quotation')]).ids"/>
            <value eval="{'color': 3}"/>
        </function>
        <!-- Won: Green (Color 10) -->
        <function model="crm.stage" name="write">
            <value model="crm.stage" eval="obj().search([('is_won', '=', True)]).ids"/>
            <value eval="{'color': 10}"/>
        </function>
    </data>
</odoo>
