<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_rv_inventory" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.rv.inventory</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes" groups="rv_app_access.group_change_confirmed_po_vendor">
                <attribute name="readonly">state == 'cancel'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
