<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rv_advance_payment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="after">
                 <block title="Advance Payments" id="rv_advance_payments">
                    <setting id="allow_sale_advance_payment_setting" help="Allow advance payments on Sales Orders">
                        <field name="allow_sale_advance_payment"/>
                    </setting>
                    <setting id="allow_purchase_advance_payment_setting" help="Allow advance payments on Purchase Orders">
                        <field name="allow_purchase_advance_payment"/>
                    </setting>
                 </block>
            </xpath>
        </field>
    </record>
</odoo>
