<odoo>
    <record id="view_task_form_inherit_whatsapp_button" model="ir.ui.view">
        <field name="name">project.task.form.inherit.whatsapp</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <!-- Add Send WhatsApp button in header -->
            <xpath expr="//header" position="inside">
                 <button name="action_send_whatsapp_task"
                         string="Send WhatsApp"
                         type="object"
                         class="btn-primary"
                         icon="fa-whatsapp"/>
            </xpath>
        </field>
    </record>
</odoo>
