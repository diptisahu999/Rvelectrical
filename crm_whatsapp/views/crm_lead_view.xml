<odoo>
    <record id="view_crm_lead_form_inherit_whatsapp_button" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.whatsapp.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/> <!-- ✅ FIXED -->
        <field name="arch" type="xml">

            <!-- Add the WhatsApp button next to "Won" -->
            <xpath expr="//header/button[@name='action_set_won_rainbowman']" position="after">
                <button name="action_send_whatsapp_lead"
                        string="Send WhatsApp"
                        type="object"
                        class="btn-primary"
                        icon="fa-whatsapp"/>
            </xpath>

        </field>
    </record>
</odoo>
