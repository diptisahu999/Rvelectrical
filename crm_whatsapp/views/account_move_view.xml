<odoo>
    <record id="view_move_form_inherit_whatsapp_button" model="ir.ui.view">
        <field name="name">account.move.form.inherit.whatsapp.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Insert WhatsApp button after the Send button -->
            <xpath expr="//header/button[@name='action_post']" position="after">
                <button name="action_send_whatsapp_invoice"
                        string="Send WhatsApp"
                        type="object"
                        class="btn-primary"
                        icon="fa-whatsapp"/>
            </xpath>

        </field>
    </record>
</odoo>
