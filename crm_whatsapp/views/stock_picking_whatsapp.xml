<odoo>
    <record id="view_picking_form_inherit_whatsapp_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.whatsapp.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- ✅ Button placed after Validate -->
            <xpath expr="//header/button[@name='button_validate']" position="after">
                <button name="action_send_whatsapp"
                        string="Send WhatsApp"
                        type="object"
                        class="btn-primary"
                        icon="fa-whatsapp"/>
            </xpath>
        </field>
    </record>
</odoo>
