<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Quotation Tree View -->
    <record id="view_quotation_tree_inherit_rv_sale_custom" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.rv_sale_custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">0</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Sale Order Kanban View -->
    <record id="view_sale_order_kanban_inherit_rv_sale_custom" model="ir.ui.view">
        <field name="name">sale.order.kanban.inherit.rv_sale_custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sale_order_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="create">0</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Sale Order Form View -->
    <record id="view_order_form_inherit_rv_sale_custom" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.rv_sale_custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">0</attribute>
            </xpath>
            <!-- Restrict Delivery Address to only the selected customer's addresses -->
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="domain">['|', ('id', '=', partner_id), ('parent_id', '=', partner_id)]</attribute>
                <attribute name="no_create">1</attribute>
                <attribute name="no_create_edit">1</attribute>
                <attribute name="no_quick_create">1</attribute>
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <!-- Restrict Invoice Address to only the selected customer's addresses -->
            <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                <attribute name="domain">['|', ('id', '=', partner_id), ('parent_id', '=', partner_id)]</attribute>
                <attribute name="no_create">1</attribute>
                <attribute name="no_create_edit">1</attribute>
                <attribute name="no_quick_create">1</attribute>
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <!-- Force Inline Creation on Mobile for Order Lines -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="mode">list</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list" position="attributes">
                <attribute name="class">o_list_editable_mobile</attribute>
            </xpath>
            <!-- Expose is_additional_charge and restrict product selection domain -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="before">
                <field name="is_additional_charge" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True), ('is_additional_product', '=', is_additional_charge)]</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True), ('is_additional_product', '=', is_additional_charge)]</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="before">
                <field name="is_additional_charge"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True), ('type', '!=', 'combo'), ('is_additional_product', '=', is_additional_charge)]</attribute>
            </xpath>
            <!-- Hide Packaging columns in order lines tree view -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_packaging_qty']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_packaging_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
