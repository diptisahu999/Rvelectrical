<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_only_form_view_inherit_rv_sale" model="ir.ui.view">
        <field name="name">product.template.only.form.inherit.rv.sale</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-flex">
                    <field name="is_additional_product"/>
                    <label for="is_additional_product"/>
                </span>
            </xpath>
        </field>
    </record>
</odoo>
