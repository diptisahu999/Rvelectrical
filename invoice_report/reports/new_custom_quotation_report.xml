                    <!-- =========================== -->
                    <!-- PAGE 2 : QUOTATION CONTENT -->
                    <!-- =========================== -->

                    <div class="page" 
                            style="position:relative;
                                width: 100%;
                                height:auto;
                                page-break-before:always;">
                        
                        <div style="padding-top:18mm; padding-bottom: 0mm; padding-left:8mm; padding-right:8mm;">
                        
                            <!-- HEADER -->
                            <!-- <table class="table p-0 mb-0" style="border: 1px solid #6c757d;">
                                <tr>
                                    <td class="col-4" 
                                            style="text-align: center; vertical-align: middle; width: 30%; 
                                                height: 120px; border-right: 1px solid #6c757d;">
