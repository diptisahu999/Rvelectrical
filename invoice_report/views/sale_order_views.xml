<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form" model="ir.ui.view">
        <field name="name">view.order.form.inherit.invoice_report</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <field name="payment_term_id" position="after">
                <field name="terms_condition_id" />
                <field name="additional_notes" />
                <!-- <field name="manual_discount"/> -->
            </field>
            <xpath expr="//field[@name='order_line']/list/field[@name='tax_id']" position="attributes">
                <attribute name="context">{'filter_taxes_by_location': True, 'partner_id': parent.partner_id, 'company_id': parent.company_id}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='tax_id']" position="attributes">
                <attribute name="context">{'filter_taxes_by_location': True, 'partner_id': parent.partner_id, 'company_id': parent.company_id}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
