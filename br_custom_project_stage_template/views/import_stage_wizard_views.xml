<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Import Stage Template Wizard Form View -->
    <record id="view_import_stage_template_wizard_form" model="ir.ui.view">
        <field name="name">import.stage.template.wizard.form</field>
        <field name="model">import.stage.template.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="project_id" readonly="1"/>
                    <field name="template_id" required="1"/>
                    <field name="import_mode" widget="radio"/>
                </group>
                <group string="Template Preview" invisible="template_id == False">
                    <div class="o_form_label">Stages that will be imported:</div>
                    <div invisible="template_id == False">
                        <field name="template_id" context="{'show_stages': True}" readonly="1" 
                               options="{'no_create': True, 'no_edit': True}"/>
                    </div>
                </group>
                <footer>
                    <button name="action_import_stages" string="Import Stages" 
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Import Stage Template Wizard Action -->
    <record id="action_import_stage_template_wizard" model="ir.actions.act_window">
        <field name="name">Import Stage Template</field>
        <field name="res_model">import.stage.template.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_project_id': active_id}</field>
    </record>
</odoo>
