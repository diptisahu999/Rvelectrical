<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stage Template List View -->
    <record id="view_project_stage_template_tree" model="ir.ui.view">
        <field name="name">project.stage.template.list</field>
        <field name="model">project.stage.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Stage Template Form View -->
    <record id="view_project_stage_template_form" model="ir.ui.view">
        <field name="name">project.stage.template.form</field>
        <field name="model">project.stage.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Stages">
                            <field name="stage_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="fold"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Stage Template Action -->
    <record id="action_project_stage_template" model="ir.actions.act_window">
        <field name="name">Stage Templates</field>
        <field name="res_model">project.stage.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_project_stage_template_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first stage template!
            </p>
            <p>
                Stage templates allow you to define reusable sets of project stages
                that can be applied to new projects.
            </p>
        </field>
    </record>

    <!-- Stage Template Wizard Form View -->
    <record id="view_project_stage_template_wizard_form" model="ir.ui.view">
        <field name="name">project.stage.template.wizard.form</field>
        <field name="model">project.stage.template.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="project_id" readonly="1"/>
                    <field name="template_id"/>
                    <field name="replace_existing"/>
                </group>
                <footer>
                    <button name="apply_template" string="Apply Template" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Menu Items -->
    <!-- <menuitem id="menu_project_stage_template"
              name="Stage Templates"
              parent="project.menu_project_config"
              action="action_project_stage_template"
              sequence="50"/> -->
</odoo>