<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tkn_adv_partner_ledger_view_form" model="ir.ui.view">
            <field name="name">tkn.adv.partner.ledger.view.form</field>
            <field name="model">report.customer.card</field>
            <field name="arch" type="xml">
                <form string="Advance Partner Ledger">
                    <header>
                        <button name="print_report" string="Print Pdf" type="object" default_focus="1"
                                class="oe_highlight"/>
                        <button name="export_xlsx_report" string="Print Excel" type="object" class="oe_highlight"/>
                        <button name="action_view_ledger" string="View Ledger" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group name="selection_group">
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                            <group>
                                <field name="partner_ids" widget="many2many_tags"/>
                                <field name="sales_person_ids" widget="many2many_tags"/>
                                <field name="journal_ids" widget="many2many_tags"/>
                                <field name="currency_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="Options">
                                <field name="partner_type" widget="radio"/>
                                <field name="moves_status" widget="radio" required="1"/>
                                <field name="show_initial_balance"/>
                                <field name="show_closing_balance"/>
                                <field name="show_details"/>
                            </group>
                            <group string="View">
                                <field name="printed_by"/>
                                <field name="print_date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tkn_adv_partner_ledger" model="ir.actions.act_window">
            <field name="name">Advance Partner Ledger</field>
            <field name="res_model">report.customer.card</field>
            <field name="view_mode">form</field>
            <field name="context"></field>
            <field name="target">current</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_tkn_adv_partner_ledger_view_form"
                  name="Advanced Partner Ledger"
                  parent="account.menu_finance_reports"
                  action="action_tkn_adv_partner_ledger"
                  sequence="99"/>

    </data>
</odoo>