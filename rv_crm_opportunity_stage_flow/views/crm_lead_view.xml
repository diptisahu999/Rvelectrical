<odoo>
    <!-- Opportunity Disable clickable statusbar (Stage) -->
    <record id="crm_lead_form_disable_stage_click" model="ir.ui.view">
        <field name="name">crm.lead.form.disable.stage.click</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stage_id']" position="replace">
                <field name="stage_id"
                       widget="statusbar"
                       readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
