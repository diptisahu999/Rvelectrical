<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for the Wizard -->
    <record id="task_library_wizard_view_form" model="ir.ui.view">
        <field name="name">task.library.wizard.form</field>
        <field name="model">task.library.wizard</field>
        <field name="arch" type="xml">
            <form>
                <p>Select the task templates you want to add to this project.</p>
                <group>
                    <field name="task_template_ids"
                           nolabel="1"
                           widget="many2many_checkboxes"
                           options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_add_tasks"
                            string="Add Tasks"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action Window for the Wizard -->
    <record id="action_task_library_wizard" model="ir.actions.act_window">
        <field name="name">Add from Task Library</field>
        <field name="res_model">task.library.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> 
        <field name="view_id" ref="task_library_wizard_view_form"/>
    </record>

</odoo>