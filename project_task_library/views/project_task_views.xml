<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_task_form2_inherit_days_left" model="ir.ui.view">
            <field name="name">project.task.form.inherit.days.left</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_deadline']" position="after">
                    <field name="x_days_left_display" 
                           readonly="1" 
                           style="font-weight: bold; color: #091E42;"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>