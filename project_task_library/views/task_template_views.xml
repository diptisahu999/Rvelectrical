<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Task Templates -->
    <record id="project_task_template_view_form" model="ir.ui.view">
        <field name="name">project.task.template.form</field>
        <field name="model">project.task.template</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. New Server Setup"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_ids" widget="many2many_tags" placeholder="e.g. John Smith"/>
                            <field name="tags_ids" widget="many2many_tags" placeholder="e.g. DevOps"/>
                            <field name="partner_id" placeholder="e.g. YourCompany"/>
                        </group>
                        <group>
                            <field name="date_deadline" readonly="1"/>
                            <field name="days_deadline"/>
                            <field name="priority"/>
                            <field name="milestone_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <label for="description"/>
                    <field name="description" placeholder="Add the default description for this task..."/>

                    <notebook>
                        <page string="Sub-task Templates" name="subtasks">
                            <field name="subtask_template_ids"
                                   context="{'default_task_template_id': id}">
                                <list string="Sub-tasks" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Sub-task Name"/>
                                    <field name="user_ids" widget="many2many_tags" string=" Assignees"/>
                                    <field name="tags_ids" widget="many2many_tags" string="Tags" column_invisible="True"/>
                                    <field name="partner_id" column_invisible="True"/>
                                    <field name="date_deadline" readonly="1"/>
                                    <field name="days_deadline"/>
                                    <field name="priority" column_invisible="True"/>
                                    <field name="milestone_id" column_invisible="True"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="user_ids" widget="many2many_tags"/>
                                                <field name="tags_ids" widget="many2many_tags" invisible="1"/>
                                                <field name="partner_id" invisible="1"/>
                                            </group>
                                            <group>
                                                <field name="date_deadline" readonly="1"/>
                                                <field name="days_deadline"/>
                                                <field name="priority" invisible="1"/>
                                                <field name="milestone_id" invisible="1"/>
                                                <field name="task_template_id" invisible="1"/>
                                            </group>
                                        </group>
                                        <label for="description"/>
                                        <field name="description" placeholder="Default sub-task description..."/>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View for Task Templates -->
    <record id="project_task_template_view_list" model="ir.ui.view">
        <field name="name">project.task.template.list</field>
        <field name="model">project.task.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="tags_ids" widget="many2many_tags"/>
                <field name="partner_id"/>
                <field name="date_deadline"/>
                <field name="priority"/>
                <field name="milestone_id" column_invisible="True"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

     <!-- Action Window for Task Templates -->
    <record id="project_task_template_action" model="ir.actions.act_window">
        <field name="name">Task Template Library</field>
        <field name="res_model">project.task.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('project_task_template_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('project_task_template_view_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Task Template
            </p><p>
                Define a library of re-usable tasks with sub-tasks. You can add them to existing projects.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_project_task_template_config"
              name="Task Template Library"
              parent="project.menu_project_config"
              action="project_task_template_action"
              sequence="10"/>

</odoo>