<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- Rule for Project Task Template -->
        <!-- User: Only see assigned templates -->
        <record id="rule_project_task_template_user_own" model="ir.rule">
            <field name="name">Project Task Template: See Own Assigned</field>
            <field name="model_id" ref="model_project_task_template"/>
            <field name="domain_force">[('user_ids', 'in', user.id)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <!-- Manager: See All Templates -->
        <record id="rule_project_task_template_manager_all" model="ir.rule">
            <field name="name">Project Task Template: Manager See All</field>
            <field name="model_id" ref="model_project_task_template"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>

        <!-- Global Rule for Project Tasks: Assignees Only (Non-Managers) -->
        <record id="rule_project_task_strict_assigned_global" model="ir.rule">
            <field name="name">Project Task: Assignee Only (Global Restriction)</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[(1, '=', 1)] if user.has_group('project.group_project_manager') else [('user_ids', 'in', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Global Rule for Projects: Only Projects with Assigned Tasks (Non-Managers) -->
        <record id="rule_project_project_strict_assigned_tasks_global" model="ir.rule">
            <field name="name">Project: Only With Assigned Tasks (Global Restriction)</field>
            <field name="model_id" ref="project.model_project_project"/>
            <!-- Show Project IF user is Manager OR IF user has at least one task assigned in the project -->
            <field name="domain_force">[(1, '=', 1)] if user.has_group('project.group_project_manager') else [('task_ids.user_ids', 'in', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
        
    </data>
</odoo>
